# Copy to .env and adjust if needed. docker compose up works with these defaults
# untouched — zero required config-file editing (constitution Principle IV).

MYSQL_ROOT_PASSWORD=txloom
MYSQL_USER=txloom
MYSQL_PASSWORD=txloom

# Overrides the auto-generated data/keys/instance.key used to encrypt sink
# credentials at rest (D14). Leave unset to let the API generate one on first boot.
# TXLOOM_INSTANCE_KEY=

# Docker volume mount for run outputs (truth/labels/exports/report.json) and the
# instance key — see data-model.md § Run-output volume layout.
DATA_DIR=./data
